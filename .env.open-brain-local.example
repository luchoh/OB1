# Open Brain Local application configuration
#
# This file is for the local app/runtime configuration, distinct from the
# workstation-level `.env` used for service discovery and admin access.

# Environment
NODE_ENV=development
OPEN_BRAIN_ENV=local

# Consul
CONSUL_HTTP_ADDR=http://127.0.0.1:8500
CONSUL_HTTP_TOKEN=00000000-0000-0000-0000-000000000000
CONSUL_FORCE_DISCOVERY=true
CONSUL_POSTGRES_SERVICE=postgresql

# PostgreSQL
PGHOST=10.10.10.100
PGPORT=5432
PGDATABASE=ob1
PGUSER=ob1
PGPASSWORD=change-me

# Canonical model services
LLM_BASE_URL=http://10.10.10.101:8035
LLM_MODEL=mlx-community/Qwen3.5-397B-A17B-nvfp4

EMBEDDING_BASE_URL=http://10.10.10.101:8082
EMBEDDING_MODEL=mlx-community/Qwen3-Embedding-8B-mxfp8

# The current ob1-embedding service returns 4096 values and ignores the
# OpenAI-compatible `dimensions` parameter. The application should truncate
# client-side to the configured storage dimension before writes and queries.
EMBEDDING_RAW_DIMENSION=4096
EMBEDDING_STORE_DIMENSION=1536
EMBEDDING_TRUNCATION_STRATEGY=prefix

# Legacy rollback embedding service
EMBEDDING_FALLBACK_BASE_URL=http://10.10.10.101:8081
EMBEDDING_FALLBACK_MODEL=nomic-ai/nomic-embed-text-v1.5-GGUF:nomic-embed-text-v1.5.Q8_0.gguf

# MCP server auth
MCP_ACCESS_KEY=change-me

# Optional service identity
OPEN_BRAIN_SERVICE_NAME=open-brain-local
OPEN_BRAIN_EMBEDDING_SERVICE_NAME=ob1-embedding
