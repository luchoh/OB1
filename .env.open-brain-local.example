# Open Brain Local application configuration
#
# This file is for the local app/runtime configuration, distinct from the
# workstation-level `.env` used for service discovery and admin access.

# Environment
NODE_ENV=development
OPEN_BRAIN_ENV=local
OPEN_BRAIN_HOST=localhost
# For a managed LAN service, bind all interfaces and advertise the host
# hostname or FQDN separately in Consul.
OPEN_BRAIN_PORT=8787

# Consul
CONSUL_HTTP_ADDR=https://consul.lincoln.luchoh.net
CONSUL_HTTP_TOKEN=00000000-0000-0000-0000-000000000000
CONSUL_SKIP_TLS_VERIFY=false
# When explicit service URLs are set below, they take precedence and Consul only
# fills missing values.
CONSUL_FORCE_DISCOVERY=true
CONSUL_POSTGRES_SERVICE=postgresql

# PostgreSQL
# Leave PGHOST / PGPORT unset to use Consul discovery of `postgresql`.
# Optional explicit override:
# PGHOST=postgresql.luchoh.net
# PGPORT=5432
PGDATABASE=ob1
PGUSER=ob1
PGPASSWORD=change-me
# Optional alternative to the PG* values above:
# OPEN_BRAIN_DATABASE_URL=postgres://ob1:change-me@postgresql.luchoh.net:5432/ob1

# Canonical model services
# Leave LLM_BASE_URL / LLM_HEALTH_URL unset to discover `mlx-server` in Consul.
# If both are set, they override Consul discovery.
# Optional explicit overrides:
# LLM_BASE_URL=http://mlx-server.luchoh.net/v1
# LLM_HEALTH_URL=http://mlx-server.luchoh.net/health
LLM_MODEL=mlx-community/Qwen3.5-397B-A17B-nvfp4
LLM_ENABLE_THINKING=false
OPEN_BRAIN_ANSWER_MAX_TOKENS=600

# Leave EMBEDDING_BASE_URL / EMBEDDING_HEALTH_URL unset to discover
# `ob1-embedding` in Consul. If both are set, they override Consul discovery.
# Optional explicit overrides:
# EMBEDDING_BASE_URL=http://ob1-embedding.luchoh.net/v1
# EMBEDDING_HEALTH_URL=http://ob1-embedding.luchoh.net/health
EMBEDDING_MODEL=mlx-community/Qwen3-Embedding-8B-mxfp8

# Canonical production contract:
# `ob1-embedding` owns dimension control and returns 1536-dimensional
# embeddings directly.
EMBEDDING_RAW_DIMENSION=1536
EMBEDDING_STORE_DIMENSION=1536
EMBEDDING_DIMENSIONS_PARAMETER=1536
EMBEDDING_ALLOWED_DIMENSIONS=1536

# Legacy rollback embedding service
# Optional rollback endpoint override:
# EMBEDDING_FALLBACK_BASE_URL=http://llama-cpp-embedding.luchoh.net/v1
EMBEDDING_FALLBACK_MODEL=nomic-ai/nomic-embed-text-v1.5-GGUF:nomic-embed-text-v1.5.Q8_0.gguf

# Offline startup / local artifact hints
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
LLM_MODEL_PATH=/models/qwen3.5-397b-a17b
EMBEDDING_MODEL_PATH=/Volumes/llama-models/mlx-embedding/.cache/huggingface/hub/models--mlx-community--Qwen3-Embedding-8B-mxfp8/snapshots/51c773b7464b630a6c67b4f75dbd796b658d6236

# MCP server auth
MCP_ACCESS_KEY=change-me

# Optional human-authenticated MCP path
# Leave disabled for local development unless you are explicitly testing the
# stable Keycloak-authenticated service model.
OB1_ENABLE_HUMAN_TOKEN_AUTH=false
# OB1_OIDC_ISSUER_URL=https://auth.lincoln.luchoh.net/realms/lincoln
# OB1_OIDC_AUDIENCE=ob1
# Optional explicit JWKS override:
# OB1_OIDC_JWKS_URL=https://auth.lincoln.luchoh.net/realms/lincoln/protocol/openid-connect/certs

# Optional service identity
OPEN_BRAIN_SERVICE_NAME=open-brain-local
OPEN_BRAIN_LLM_SERVICE_NAME=mlx-server
OPEN_BRAIN_EMBEDDING_SERVICE_NAME=ob1-embedding

# Graph / Neo4j
# Keep disabled until you have local Neo4j auth configured.
OPEN_BRAIN_GRAPH_ENABLED=false
# Leave NEO4J_URI unset to discover `neo4j-enterprise` via Consul.
# If set, it overrides Consul discovery.
# Optional explicit override:
# NEO4J_URI=bolt://localhost:7687
OPEN_BRAIN_GRAPH_SERVICE_NAME=neo4j-enterprise
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
OPEN_BRAIN_GRAPH_DATABASE=ob1-graph
OPEN_BRAIN_GRAPH_STAGING_DATABASE=ob1-graph-stage
OPEN_BRAIN_GRAPH_PROJECTOR_INTERVAL_SECONDS=60
OPEN_BRAIN_GRAPH_PROJECTOR_BATCH_SIZE=100

# Document import / Docling
# Leave DOCLING_BASE_URL / DOCLING_HEALTH_URL unset to use Consul discovery.
# Uncomment only if you need to bypass Consul temporarily.
# DOCLING_BASE_URL=http://docling.luchoh.net
# DOCLING_HEALTH_URL=http://docling.luchoh.net/health
DOCLING_SERVICE_NAME=docling
DOCLING_FALLBACK_SERVICE_NAME=docling-markdown
DOCLING_OCR_ENABLED=true
DOCLING_FORCE_OCR=false
DOCLING_OCR_ENGINE=tesseract
DOCLING_OCR_LANG=bul,eng
DOCLING_VLM_FALLBACK_ENABLED=true
DOCLING_VLM_FALLBACK_MIN_TEXT_CHARS_PDF=500
DOCLING_VLM_FALLBACK_MIN_TEXT_CHARS_IMAGE=120
DOCLING_VLM_FALLBACK_MAX_SHORT_LINE_RATIO=0.35
DOCLING_VLM_FALLBACK_MIN_ALNUM_RATIO=0.55
DOCLING_VLM_FALLBACK_MAX_DUPLICATE_LINE_RATIO=0.30
DOCLING_VLM_FALLBACK_MIN_LEXICAL_VARIETY=0.18
DOCLING_VLM_FALLBACK_MIN_TOKEN_COUNT_FOR_VARIETY=200
DOCLING_VLM_FALLBACK_REQUIRED_SOFT_FAILS=2

# MinIO artifact retention
# Runtime contract:
# - local development may use static MINIO_* credentials
# - local development should still use a dedicated scoped OB1 credential, not the MinIO root/admin credential
# - managed services should use per-service MinIO credentials that still
#   materialize as the same MINIO_* env vars at process start
# - MinIO endpoint discovery should go through Consul via MINIO_SERVICE_NAME
# - MINIO_ENDPOINT is only an explicit override for isolated/manual runs
# See docs/18-sysadmin-minio-auth-request.md
# MINIO_SERVICE_NAME=minio
# MINIO_ENDPOINT=minio.example.internal:9000
# MINIO_ACCESS_KEY=change-me
# MINIO_SECRET_KEY=change-me
# MINIO_SECURE=false
# OPEN_BRAIN_DOCUMENT_MINIO_BUCKET=open-brain-document-originals
# OPEN_BRAIN_DOCUMENT_MINIO_PREFIX=documents
# OPEN_BRAIN_DOCUMENT_RETAIN_ARTIFACTS=false
# OPEN_BRAIN_IMAP_ATTACHMENT_MARKDOWN_MINIO_BUCKET=open-brain-document-originals
# OPEN_BRAIN_IMAP_ATTACHMENT_MARKDOWN_MINIO_PREFIX=imap-attachments/markdown
# OPEN_BRAIN_IMAP_RETAIN_ATTACHMENT_MARKDOWN=false

# Telegram thought review
# Default is `full`, which shows candidate thoughts in Telegram and waits for
# Commit before ingesting Telegram-origin text or dictation thoughts.
# Set to `exceptions_only` to keep the older auto-ingest path and only prompt
# for ambiguous, duplicate, or empty-thought cases.
# TELEGRAM_REVIEW_MODE=full
# TELEGRAM_REVIEW_STATE_FILE=/usr/local/var/ob1-telegram-bridge/telegram-review-state.json

# IMAP auto-ingest
IMAP_HOST=mail.example.com
IMAP_PORT=993
# Use IMAP_USERNAME if your provider requires a username different from the
# mailbox address. The importer already knows how to fall back from
# `user@example.com` to `user` when the server requires the local-part only.
IMAP_ACCOUNT=ob1@example.com
# IMAP_USERNAME=ob1
IMAP_PASSWORD=change-me
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_SECONDS=60
IMAP_ERROR_BACKOFF_SECONDS=300
