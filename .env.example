# Local database/discovery configuration
DATABASE_TYPE=postgres

# Consul
CONSUL_HTTP_ADDR=http://127.0.0.1:8500
CONSUL_HTTP_TOKEN=00000000-0000-0000-0000-000000000000
CONSUL_POSTGRES_SERVICE=postgresql
CONSUL_FORCE_DISCOVERY=true

# PostgreSQL
POSTGRES_USER=ob1
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ob1
